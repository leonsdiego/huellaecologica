<?php
$pagina      = $this->pagina;
$totalPaginas = $this->totalPaginas;
$rol         = $this->rol;
$total       = $this->total;

function paginaUrl($rol, $p) {
    return '/../editor/listar/tipo/' . $rol . '/pagina/' . $p;
}
?>
<div class="flex items-center justify-between mb-3">
  <h2 class="text-lg font-bold text-gray-700"><?= $this->titulo ?></h2>
  <span class="text-xs text-gray-400"><?= $total ?> registros</span>
</div>
<hr class="border-gray-300 mb-4" />

<table class="w-full text-sm">
  <thead>
    <tr class="border-b-2 border-gray-300">
      <th class="text-left pb-2 pr-4 font-semibold text-gray-600">Correo electr&oacute;nico</th>
      <th class="text-left pb-2 pr-4 font-semibold text-gray-600">Cuestionarios</th>
      <th class="text-left pb-2 font-semibold text-gray-600">Estatus</th>
    </tr>
  </thead>
  <tbody>
    <?php foreach($this->usuarios as $usuario): ?>
    <?php $activo = $usuario['estatus_usuario'] == 1; ?>
    <tr class="border-b border-gray-100 hover:bg-green-50">
      <td class="py-2 pr-4">
        <a href="<?php echo $this->url(array('action'=>'perfil','id'=>$usuario['id_usuario'])); ?>"
           class="text-green-700 hover:underline">
          <?= $usuario['email_usuario'] ?>
        </a>
      </td>
      <td class="py-2 pr-4 text-gray-700"><?= $usuario['cuestionarios'] ?></td>
      <td class="py-2">
        <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full
          <?= $activo ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' ?>">
          <?= $activo ? 'Activo' : 'Inactivo' ?>
        </span>
      </td>
    </tr>
    <?php endforeach; ?>
  </tbody>
</table>

<?php if ($totalPaginas > 1): ?>
<div class="flex items-center justify-between mt-5 pt-4 border-t border-gray-200">

  <!-- Prev -->
  <?php if ($pagina > 1): ?>
    <a href="<?= paginaUrl($rol, $pagina - 1) ?>"
       class="px-3 py-1.5 text-sm bg-white border border-gray-300 rounded hover:bg-gray-50 text-gray-600">
      &larr; Anterior
    </a>
  <?php else: ?>
    <span class="px-3 py-1.5 text-sm border border-gray-200 rounded text-gray-300 cursor-not-allowed">&larr; Anterior</span>
  <?php endif; ?>

  <!-- Page numbers -->
  <div class="flex gap-1">
    <?php
    $window = 2;
    $start  = max(1, $pagina - $window);
    $end    = min($totalPaginas, $pagina + $window);
    if ($start > 1): ?>
      <a href="<?= paginaUrl($rol, 1) ?>" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-50 text-gray-600">1</a>
      <?php if ($start > 2): ?><span class="px-2 py-1.5 text-sm text-gray-400">&hellip;</span><?php endif; ?>
    <?php endif; ?>

    <?php for ($p = $start; $p <= $end; $p++): ?>
      <?php if ($p === $pagina): ?>
        <span class="px-3 py-1.5 text-sm bg-green-700 text-white rounded font-semibold"><?= $p ?></span>
      <?php else: ?>
        <a href="<?= paginaUrl($rol, $p) ?>" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-50 text-gray-600"><?= $p ?></a>
      <?php endif; ?>
    <?php endfor; ?>

    <?php if ($end < $totalPaginas): ?>
      <?php if ($end < $totalPaginas - 1): ?><span class="px-2 py-1.5 text-sm text-gray-400">&hellip;</span><?php endif; ?>
      <a href="<?= paginaUrl($rol, $totalPaginas) ?>" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-50 text-gray-600"><?= $totalPaginas ?></a>
    <?php endif; ?>
  </div>

  <!-- Next -->
  <?php if ($pagina < $totalPaginas): ?>
    <a href="<?= paginaUrl($rol, $pagina + 1) ?>"
       class="px-3 py-1.5 text-sm bg-white border border-gray-300 rounded hover:bg-gray-50 text-gray-600">
      Siguiente &rarr;
    </a>
  <?php else: ?>
    <span class="px-3 py-1.5 text-sm border border-gray-200 rounded text-gray-300 cursor-not-allowed">Siguiente &rarr;</span>
  <?php endif; ?>

</div>
<?php endif; ?>
