<div class="titulo"><h2>Cuestionario</h2></div><hr /><?php foreach($this->grupos as $grupo): ?><div class="tituloGrupo"><h2><a href="<?php echo $this->url(array('action'=>'grupo','id'=>$grupo['id_grupo'])); ?>"><?= $grupo['nombre_grupo']?></a></h2></div>	<?php foreach($this->indicadores as $indicador): ?>		<?php if($indicador['tbl_grupo_id_grupo'] == $grupo['id_grupo'] && $indicador['estatus_indicador'] == 1): ?>			<div class="tituloIndicador"><p>P.<?= $indicador['orden_indicador'] ?> <a href="<?php echo $this->url(array('action'=>'indicador','id'=>$indicador['id_indicador'])); ?>"><?= $indicador['descripcion_indicador'] ?></a> FC: <a href="<?php echo $this->url(array('action'=>'factor','id'=>$indicador['id_factorConversion'])); ?>"><?= $indicador['id_factorConversion'] ?>) <?= $indicador['valor_factorConversion'] ?></a></p></div>				<?php foreach($this->alternativas as $alternativa): ?>					<?php if($alternativa['tbl_indicador_id_indicador'] == $indicador['id_indicador']): ?>						<table>							<tr>								<td><?= $alternativa['orden_alternativa'] ?>)</td>								<td class="tituloAlternativa"><p><a href="<?php echo $this->url(array('action'=>'alternativa','id'=>$alternativa['id_alternativa'])); ?>"><?= $alternativa['descripcion_alternativa'] ?></a></p></td>								<td>Peso: <?= $alternativa['peso_alternativa'] ?></td>							</tr>						</table>					<?php endif; ?>				<?php endforeach; ?>		<?php endif; ?>	<?php endforeach; ?><?php endforeach; ?>