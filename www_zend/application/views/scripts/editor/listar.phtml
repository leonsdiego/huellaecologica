<?php
$pagina       = $this->pagina;
$totalPaginas = $this->totalPaginas;
$rol          = $this->rol;
$total        = $this->total;
$search       = $this->search;
$filtro       = $this->filtro;

function paginaUrl($rol, $p, $search, $filtro) {
    $url    = '/../editor/listar/tipo/' . $rol . '/pagina/' . $p;
    $params = array();
    if ($search !== '') $params[] = 'search=' . urlencode($search);
    if ($filtro !== '') $params[] = 'cuestionarios=' . urlencode($filtro);
    return empty($params) ? $url : $url . '?' . implode('&', $params);
}

$filtroLabels = array(
    'ninguno' => 'Ninguno',
    'uno'     => 'Solo uno',
    'mas'     => 'Más de uno',
);
?>

<!-- Header row -->
<div class="flex items-center justify-between mb-3">
  <h2 class="text-lg font-bold text-gray-700"><?= $this->titulo ?></h2>
  <span class="text-xs text-gray-400"><?= $total ?> registros</span>
</div>

<!-- Search + filter bar -->
<form method="get" action="/../editor/listar/tipo/<?= htmlspecialchars($rol) ?>"
      class="flex gap-2 mb-4 flex-wrap">

  <input type="text"
         name="search"
         value="<?= htmlspecialchars($search) ?>"
         placeholder="Buscar por correo..."
         class="flex-1 min-w-0 border border-gray-300 rounded px-3 py-1.5 text-sm bg-white focus:outline-none focus:border-green-500"
         style="min-width:200px;" />

  <select name="cuestionarios"
          class="border border-gray-300 rounded px-3 py-1.5 text-sm bg-white focus:outline-none focus:border-green-500">
    <option value="">Cuestionarios completados: todos</option>
    <option value="ninguno" <?= $filtro === 'ninguno' ? 'selected' : '' ?>>Ninguno</option>
    <option value="uno"     <?= $filtro === 'uno'     ? 'selected' : '' ?>>Solo uno</option>
    <option value="mas"     <?= $filtro === 'mas'     ? 'selected' : '' ?>>Más de uno</option>
  </select>

  <button type="submit"
          class="px-4 py-1.5 bg-green-700 hover:bg-green-800 text-white text-sm font-semibold rounded cursor-pointer transition-colors">
    Buscar
  </button>

  <?php if ($search !== '' || $filtro !== ''): ?>
  <a href="/../editor/listar/tipo/<?= htmlspecialchars($rol) ?>"
     class="px-4 py-1.5 border border-gray-300 rounded text-sm text-gray-500 hover:bg-gray-100 transition-colors">
    Limpiar
  </a>
  <?php endif; ?>

</form>

<!-- Active filter pills -->
<?php if ($search !== '' || $filtro !== ''): ?>
<div class="flex gap-2 mb-3 flex-wrap">
  <?php if ($search !== ''): ?>
    <span class="inline-flex items-center gap-1 text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">
      Correo: <strong><?= htmlspecialchars($search) ?></strong>
    </span>
  <?php endif; ?>
  <?php if ($filtro !== ''): ?>
    <span class="inline-flex items-center gap-1 text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">
      Cuestionarios: <strong><?= htmlspecialchars($filtroLabels[$filtro]) ?></strong>
    </span>
  <?php endif; ?>
</div>
<?php endif; ?>

<hr class="border-gray-300 mb-4" />

<?php if (empty($this->usuarios)): ?>
  <p class="text-sm text-gray-400 text-center py-8">No se encontraron usuarios.</p>
<?php else: ?>

<table class="w-full text-sm">
  <thead>
    <tr class="border-b-2 border-gray-300">
      <th class="text-left pb-2 pr-4 font-semibold text-gray-600">Correo electr&oacute;nico</th>
      <th class="text-left pb-2 pr-4 font-semibold text-gray-600">Cuestionarios</th>
      <th class="text-left pb-2 font-semibold text-gray-600">Estatus</th>
    </tr>
  </thead>
  <tbody>
    <?php foreach($this->usuarios as $usuario): ?>
    <?php $activo = $usuario['estatus_usuario'] == 1; ?>
    <tr class="border-b border-gray-100 hover:bg-green-50">
      <td class="py-2 pr-4">
        <a href="<?php echo $this->url(array('action'=>'perfil','id'=>$usuario['id_usuario'])); ?>"
           class="text-green-700 hover:underline">
          <?= htmlspecialchars($usuario['email_usuario']) ?>
        </a>
      </td>
      <td class="py-2 pr-4 text-gray-700"><?= $usuario['cuestionarios'] ?></td>
      <td class="py-2">
        <span class="inline-block text-xs font-medium px-2 py-0.5 rounded-full
          <?= $activo ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' ?>">
          <?= $activo ? 'Activo' : 'Inactivo' ?>
        </span>
      </td>
    </tr>
    <?php endforeach; ?>
  </tbody>
</table>

<?php if ($totalPaginas > 1): ?>
<div class="flex items-center justify-between mt-5 pt-4 border-t border-gray-200">

  <?php if ($pagina > 1): ?>
    <a href="<?= paginaUrl($rol, $pagina - 1, $search, $filtro) ?>"
       class="px-3 py-1.5 text-sm bg-white border border-gray-300 rounded hover:bg-gray-50 text-gray-600">
      &larr; Anterior
    </a>
  <?php else: ?>
    <span class="px-3 py-1.5 text-sm border border-gray-200 rounded text-gray-300 cursor-not-allowed">&larr; Anterior</span>
  <?php endif; ?>

  <div class="flex gap-1">
    <?php
    $window = 2;
    $start  = max(1, $pagina - $window);
    $end    = min($totalPaginas, $pagina + $window);
    if ($start > 1): ?>
      <a href="<?= paginaUrl($rol, 1, $search, $filtro) ?>" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-50 text-gray-600">1</a>
      <?php if ($start > 2): ?><span class="px-2 py-1.5 text-sm text-gray-400">&hellip;</span><?php endif; ?>
    <?php endif; ?>

    <?php for ($p = $start; $p <= $end; $p++): ?>
      <?php if ($p === $pagina): ?>
        <span class="px-3 py-1.5 text-sm bg-green-700 text-white rounded font-semibold"><?= $p ?></span>
      <?php else: ?>
        <a href="<?= paginaUrl($rol, $p, $search, $filtro) ?>" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-50 text-gray-600"><?= $p ?></a>
      <?php endif; ?>
    <?php endfor; ?>

    <?php if ($end < $totalPaginas): ?>
      <?php if ($end < $totalPaginas - 1): ?><span class="px-2 py-1.5 text-sm text-gray-400">&hellip;</span><?php endif; ?>
      <a href="<?= paginaUrl($rol, $totalPaginas, $search, $filtro) ?>" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-50 text-gray-600"><?= $totalPaginas ?></a>
    <?php endif; ?>
  </div>

  <?php if ($pagina < $totalPaginas): ?>
    <a href="<?= paginaUrl($rol, $pagina + 1, $search, $filtro) ?>"
       class="px-3 py-1.5 text-sm bg-white border border-gray-300 rounded hover:bg-gray-50 text-gray-600">
      Siguiente &rarr;
    </a>
  <?php else: ?>
    <span class="px-3 py-1.5 text-sm border border-gray-200 rounded text-gray-300 cursor-not-allowed">Siguiente &rarr;</span>
  <?php endif; ?>

</div>
<?php endif; ?>

<?php endif; ?>
